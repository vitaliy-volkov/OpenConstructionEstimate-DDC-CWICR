# =============================================================
# DDC CWICR Examples — Environment Variables
# =============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================

# --- Tier 1: Parquet examples (no keys needed) ---
# No environment variables required for basic data loading.

# --- Tier 2: Qdrant semantic search ---
# OpenAI API key for generating embeddings (text-embedding-3-large)
OPENAI_API_KEY=sk-...

# Qdrant connection (leave defaults for local Docker)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- Tier 3: LLM integration ---
# Anthropic API key for Claude examples
ANTHROPIC_API_KEY=sk-ant-...

# --- Optional ---
# BuildCalculator API (no key needed, public endpoint)
BUILDCALCULATOR_API_URL=https://buildcalculator.io/api/v1
